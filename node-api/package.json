{
  "name": "api",
  "version": "1.0.0",
  "description": "",
  "main": "src/server.ts",
  "scripts": {
    "dev": "nodemon",
    "migration:run": "typeorm-ts-node-commonjs -d ./src/database/data-source.ts migration:run",
    "migration:revert": "typeorm-ts-node-commonjs -d ./src/database/data-source.ts migration:revert",
    "migration:show": "typeorm-ts-node-commonjs -d ./src/database/data-source.ts migration:show",
    "migration:create": "typeorm-ts-node-commonjs migration:create ./src/database/migrations/migrationCreateUser",
    "migration:generate": "typeorm-ts-node-commonjs -d ./src/database/data-source.ts migration:generate ./src/database/migrations/alterarUsuario",
    "seed": "ts-node ./src/database/seeds/run-seeds.ts"
  },
  "keywords": [],
